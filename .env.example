# Copy this file to .env, then fill the values below.

# Choose one: openai, gemini, rules
AI_PROVIDER=rules
# To enable AI scoring later, use AI_PROVIDER=gemini or AI_PROVIDER=openai.

# OpenAI option
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini option
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Choose one: ntfy, telegram, discord
# Recommendation if Telegram registration is blocked by SMS fee: use ntfy.
NOTIFIER=ntfy

# ntfy option: free push notification channel, no account required.
# IMPORTANT: use a long random topic name because public ntfy.sh topics are guessable if simple.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=job-fit-radar-change-this-to-a-long-random-name
NTFY_TITLE=Job Fit Radar
NTFY_TAGS=briefcase
NTFY_PRIORITY=default

# Telegram option
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord option
DISCORD_WEBHOOK_URL=

# Runtime
DATABASE_PATH=jobs.db
